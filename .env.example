NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Text generation (RAG answer)
NVIDIA_GEN_MODEL=meta/llama-3.3-70b-instruct
KIMI_THINKING=false

# Background contextualization (offline ingest)
NVIDIA_CTX_MODEL=meta/llama-3.1-8b-instruct

# Vision (image + video keyframes)
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Audio / video transcription (faster-whisper, local)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# Video keyframe sampling
VIDEO_FRAME_EVERY_SEC=60
VIDEO_MAX_FRAMES=8

QDRANT_URL=http://localhost:6333
